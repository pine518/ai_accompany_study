# 环境变量配置示例

# 应用标题
VITE_TITLE=EduAI Campus 管理平台

# API基础路径
VITE_API_BASE_URL=/

# 公共路径
VITE_PUBLIC_PATH=/

# 是否使用hash路由
VITE_USE_HASH=false

# 首页路径
VITE_HOME_PATH=/eduai/dashboard

# 子系统前端入口地址映射（用于 admin 端单点登录跳转）
# JSON 格式，key 对应 sys_client.clientCode
# 菜单里如果直接配置了完整 URL，会优先使用菜单 URL 中的地址
VITE_SSO_TARGET_BASE_URLS={"forge_report":"http://localhost:3021/forge-report"}

# 兼容旧配置：forge_report 未在上面的映射中配置时，使用这个地址兜底
VITE_REPORT_UI_BASE_URL=http://localhost:3021/forge-report

# 客户端配置（新增）
# 客户端AppId
VITE_APP_ID=eduai_pc

# 客户端AppSecret（可选，启用客户端验证时需要）
# 注意：生产环境建议使用更安全的方式管理密钥，不要直接写在这里
# VITE_APP_SECRET=your_app_secret_here
